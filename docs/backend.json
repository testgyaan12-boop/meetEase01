
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a registered user of the MeetEase application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "createdAt", "updatedAt"]
    },
    "AvailableSlot": {
      "title": "AvailableSlot",
      "type": "object",
      "description": "Represents a specific time slot for meetings.",
      "properties": {
        "id": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "isBooked": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "meetingId": { "type": "string" }
      },
      "required": ["id", "startTime", "endTime", "isBooked", "isActive"]
    },
    "Meeting": {
      "title": "Meeting",
      "type": "object",
      "description": "Represents a meeting request.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "clientMobile": { "type": "string" },
        "description": { "type": "string" },
        "paymentProofUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "rejected", "cancelled", "done"] },
        "availableSlotId": { "type": "string" },
        "meetingLink": { "type": "string", "format": "uri" },
        "adminNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "clientName", "clientEmail", "clientMobile", "description", "paymentProofUrl", "status", "availableSlotId", "createdAt", "updatedAt"]
    },
    "AdminNotification": {
      "title": "AdminNotification",
      "type": "object",
      "description": "System notification for admins.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "meetingId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "message", "isRead", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/availableSlots/{slotId}": { "schema": "AvailableSlot", "description": "Meeting slots" },
    "/meetings/{meetingId}": { "schema": "Meeting", "description": "Meeting requests" },
    "/roles_admin/{adminUid}": { "schema": "User", "description": "Admins" },
    "/admin_notifications/{notificationId}": { "schema": "AdminNotification", "description": "Admin alerts" }
  }
}
