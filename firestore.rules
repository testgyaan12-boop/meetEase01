rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLOBAL ADMIN BYPASS
     * The UID 'hKv5CWVQv7YvJk8mLyCY11ec96O2' has absolute access to all documents.
     */
    function isSuperAdmin() {
      return request.auth != null && request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Collection Rules
    
    match /availableSlots/{slotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /meetings/{meetingId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Catch-all for super admin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}