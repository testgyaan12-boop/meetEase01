rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2' || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    
    // MEETINGS
    match /meetings/{meetingId} {
      // Allow public read for availability checks in guest booking flow
      allow read: if true;
      
      allow create: if true;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // ADMIN NOTIFICATIONS - Anyone can create, only admins read
    match /admin_notifications/{notificationId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // AVAILABLE SLOTS - Public read
    match /availableSlots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ROLES ADMIN - Authenticated users can read
    match /roles_admin/{adminUid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
  }
}