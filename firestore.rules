rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }
    
    function isAdmin() {
      return isSuperAdmin() || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    // PUBLIC - Available slots
    match /availableSlots/{slotId} {
      allow read, write: if true;
    }
    
    // MEETINGS - Fixed
    match /meetings/{meetingId} {
      allow read: if isSignedIn();  // read = get + list dono
      allow write: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Admin roles
    match /roles_admin/{adminUid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}