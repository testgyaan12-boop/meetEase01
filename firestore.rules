
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. ABSOLUTE GLOBAL BYPASS FOR SUPER ADMIN
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }
    
    // 2. PUBLIC/USER ACCESSIBLE COLLECTIONS
    match /availableSlots {
      allow list: if true;
    }
    match /availableSlots/{slotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /meetings {
      allow list: if true;
      allow create: if true;
    }
    match /meetings/{meetingId} {
      allow read: if true;
      allow write: if true;
    }

    match /admin_notifications {
      allow list: if true;
      allow create: if true;
    }
    match /admin_notifications/{notifId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /roles_admin/{adminUid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }
  }
}
