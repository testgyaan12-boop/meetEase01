rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }
    
    // Meetings - Sab signed-in users read/create kar sakte hain
    match /meetings/{meetingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }
    
    // Admin Notifications - Sab create kar sakte hain, sirf admin read
    match /admin_notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSuperAdmin();
    }
    
    // Available Slots
    match /availableSlots/{slotId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    // Roles Admin - Authenticated users can read, only super admin can write
    match /roles_admin/{adminUid} {
      allow read: if isSignedIn();  // ✅ YEH LINE ADD KARO
      allow write: if isSuperAdmin();
      allow list: if isSuperAdmin();
    }
    
    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn();
    }
  }
}