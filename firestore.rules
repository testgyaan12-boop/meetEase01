rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
         request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2');
    }

    // Admin Notifications
    match /admin_notifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Available Slots
    match /availableSlots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Roles Admin
    match /roles_admin/{adminUid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}