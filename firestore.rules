
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == 'hKv5CWVQv7YvJk8mLyCY11ec96O2';
    }
    
    function isAdmin() {
      return isSuperAdmin() || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 1. ABSOLUTE PRIORITY: SUPER ADMIN BYPASS
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
    
    // 2. PUBLIC/USER ACCESSIBLE COLLECTIONS
    match /availableSlots {
      allow list: if true;
      allow read: if true;
    }
    match /availableSlots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /meetings {
      allow list: if true;
      allow create: if true;
    }
    match /meetings/{meetingId} {
      allow read: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /admin_notifications {
      allow create: if isSignedIn();
      allow list, read, update: if isAdmin();
    }
    
    // 3. USER PROFILES
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // 4. ADMIN ROLES
    match /roles_admin/{adminUid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
